# MikroTik RouterOS API connection
MIKROTIK_HOST=
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=
MIKROTIK_TLS=false
MIKROTIK_TLS_VERIFY=false
MIKROTIK_TIMEOUT=10
REJECT_ZERO_COORDINATES=true

# GPS source: mikrotik or manual
# This is reloaded automatically while the service is running.
GPS_SOURCE=mikrotik

# Manual test coordinates. Set GPS_SOURCE=manual to use these.
MANUAL_LAT=
MANUAL_LON=
MANUAL_ALT=0.0

# Poll RouterOS every N seconds and write NMEA every N seconds.
# These are reloaded automatically while the service is running.
POLL_INTERVAL=30
# 0 means retry forever until the first valid fix, which is best for unattended use.
STARTUP_TIMEOUT=0
NMEA_WRITE_INTERVAL=1

# Virtual serial devices used between this script and Victron gps-dbus.
NMEA_VIRTUAL_DEVICE=/dev/ttyACM0
NMEA_WRITE_DEVICE=/tmp/mikrotik_gps_write
GPS_DBUS_BINARY=/opt/victronenergy/gps-dbus/gps_dbus
