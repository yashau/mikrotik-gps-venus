#!/bin/sh
set -eu

APP_DIR="${APP_DIR:-/data/mikrotik-gps-venus}"

cd "$APP_DIR"
./mikrotik_gps_venus.py stop || true

pids="$(ps w | awk '/[m]ikrotik_gps_venus.py .*start/ {print $1}')"
if [ -n "$pids" ]; then
    # shellcheck disable=SC2086
    kill -TERM $pids 2>/dev/null || true
    sleep 2

    for pid in $pids; do
        if kill -0 "$pid" 2>/dev/null; then
            kill -KILL "$pid" 2>/dev/null || true
        fi
    done
fi

killall gps_dbus 2>/dev/null || true
killall socat 2>/dev/null || true
rm -f /dev/ttyACM0 /tmp/mikrotik_gps_write /tmp/starlink_gps_write

echo "MikroTik GPS bridge stopped."
